{
  "name": "ts-narrow",
  "description": "typescript type predicates with no dependencies",
  "module": "./lib/esm/index.js",
  "main": "./lib/cjs/index.js",
  "files": [
    "lib/"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "rm -rf lib && npx tsc -p ./tsconfig.build.json && npx tsc -p ./tsconfig-cjs.json && ./fixup"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axle-dev/ts-narrow.git"
  },
  "keywords": [
    "typescript"
  ],
  "author": "Gabriel Rocha de Oliveira",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/axle-dev/ts-narrow/issues"
  },
  "homepage": "https://github.com/axle-dev/ts-narrow#readme",
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "exports": {
    "import": "./lib/esm/index.js",
    "require": "./lib/cjs/index.js"
  },
  "version": "0.31.0"
}
