{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ES2020",
    "rootDir": "src",
    "types": ["vitest/globals"],
    "declaration": true,
    "outDir": "lib/esm",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts"]
}
